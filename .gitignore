# Virtual environment
venv/
.venv/

# LLM and editor
.vscode/
.claude/

# Environment secrets
.env

# Local user preferences (contains machine-specific paths)
user_settings.json

# System
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/

# Video and image data — keep out of git (use VIDEO_DIR in config.py instead)
data/*.mp4
data/*.avi
data/*.mov
data/*.mkv
data/*.tiff
data/*.tif
data/*.png
data/*.jpg

# Pipeline outputs — large cached arrays, plots
outputs/

# Model weights — large binary files
weights/

# Jupyter checkpoints
.ipynb_checkpoints/

# Calibration — keep JSON and annotated PNGs (small, scientifically important)
# Only exclude raw hi-res source images if they are large
calibration/*.tiff
calibration/*.tif

# Project Record - New/Open/Save feature using JSON files
project_folder/
